generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id             String    @id @default(uuid())
  recipientEmail String
  fileName       String?
  status         JobStatus @default(PENDING)
  summary        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

enum JobStatus {
  PENDING
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}
